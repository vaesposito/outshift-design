<%- include('partials/head') %>
<%- include('partials/header') %>

<!-- Animated Blobs -->
<div class="blobs-container">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
</div>

<!-- Research Hero -->
<div class="research-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Home</a> <span>/</span> Research
    </div>
    <div class="research-hero-title">
      <h1><%= hero.title %></h1>
    </div>
    <div class="research-hero-inner">
      <div class="research-hero-text">
        <p><%= hero.description %></p>
      </div>
      <div class="research-hero-image">
        <% if (hero.darkImage) { %>
        <img class="img-light" src="<%= hero.image %>" alt="<%= hero.title %>">
        <img class="img-dark" src="<%= hero.darkImage %>" alt="<%= hero.title %>">
        <% } else { %>
        <img src="<%= hero.image %>" alt="<%= hero.title %>">
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Section Title -->
<div class="research-section-header">
  <div class="container">
    <h2><%= sectionHeader.title %></h2>
    <p><%= sectionHeader.subtitle %></p>
  </div>
</div>

<!-- Research Cards -->
<div class="research-cards">
  <div class="container">
    <% researchItems.forEach(function(item, idx) { %>
    <a href="<%= item.href || '#' %>" class="research-card<%= idx % 2 === 1 ? ' research-card--right' : '' %>">
      <div class="research-card-image">
        <% if (item.darkImage) { %>
        <img class="img-light" src="<%= item.image %>" alt="<%= item.title %>">
        <img class="img-dark" src="<%= item.darkImage %>" alt="<%= item.title %>">
        <% } else { %>
        <img src="<%= item.image %>" alt="<%= item.title %>">
        <% } %>
      </div>
      <div class="research-card-text">
        <h3><%= item.title %></h3>
        <p><%= item.description %></p>
        <span class="read-more">Read more &rarr;</span>
      </div>
    </a>
    <% if (item.subtopics && item.subtopics.length) { %>
    <div class="research-subcards" aria-label="<%= item.title %> subtopics">
      <% item.subtopics.forEach(function(sub) { %>
      <a class="research-subcard" href="<%= sub.href || '#' %>">
        <div class="research-subcard-image">
          <% if (sub.darkImage) { %>
          <img class="img-light" src="<%= sub.image %>" alt="<%= sub.title %>">
          <img class="img-dark" src="<%= sub.darkImage %>" alt="<%= sub.title %>">
          <% } else { %>
          <img src="<%= sub.image %>" alt="<%= sub.title %>">
          <% } %>
        </div>
        <div class="research-subcard-text">
          <h4><%= sub.title %></h4>
          <p><%= sub.shortDescription || sub.description %></p>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>
    <% }) %>
  </div>
</div>

<%- include('partials/footer') %>

<%- include('partials/head') %>
<%- include('partials/header') %>

<!-- Animated Blobs -->
<div class="blobs-container">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
</div>

<!-- Research Hero -->
<div class="research-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="/research">Research</a> <span>/</span> Hax
    </div>
    <div class="research-hero-title">
      <h1><%= hero.title %></h1>
    </div>
    <div class="research-hero-inner">
      <div class="research-hero-text">
        <p><%= hero.description %></p>
      </div>
      <div class="research-hero-image">
        <img src="<%= hero.image %>" alt="<%= hero.title %>">
      </div>
    </div>
  </div>
</div>

<!-- Section Title -->
<div class="research-section-header">
  <div class="container">
    <h2><%= sectionHeader.title %></h2>
    <p><%= sectionHeader.subtitle %></p>
  </div>
</div>

<!-- Research Cards -->
<div class="research-cards">
  <div class="container">
    <% researchItems.forEach(function(item) { %>
    <a href="<%= item.href || '#' %>" class="research-card">
      <div class="research-card-image">
        <img src="<%= item.image %>" alt="<%= item.title %>">
      </div>
      <div class="research-card-text">
        <h3><%= item.title %></h3>
        <p><%= item.description %></p>
        <span class="read-more">Read more &rarr;</span>
      </div>
    </a>
    <% }) %>
  </div>
</div>

<!-- Build with SDK -->
<div class="sdk-section">
  <div class="container">
    <div class="sdk-inner">
      <div class="sdk-text">
        <h2><%= cta.title %></h2>
        <p><%= cta.description %></p>
        <a href="<%= cta.buttonUrl %>"><button><%= cta.buttonLabel %></button></a>
      </div>
      <div class="sdk-image">
        <img src="<%= cta.image %>" alt="<%= cta.title %>">
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

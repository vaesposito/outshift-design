<%- include('partials/head') %>
<%- include('partials/header') %>

<!-- Animated Blobs -->
<div class="blobs-container">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
</div>

<!-- Research Hero -->
<div class="research-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="/research">Research</a> <span>/</span> Hax
    </div>
    <div class="research-hero-title">
      <h1><%= hero.title %></h1>
    </div>
    <div class="research-hero-inner">
      <div class="research-hero-text">
        <p><%= hero.description %></p>
      </div>
      <div class="research-hero-image">
        <% if (hero.darkImage) { %>
        <img class="img-light" src="<%= hero.image %>" alt="<%= hero.title %>">
        <img class="img-dark" src="<%= hero.darkImage %>" alt="<%= hero.title %>">
        <% } else { %>
        <img src="<%= hero.image %>" alt="<%= hero.title %>">
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Section Title -->
<div class="research-section-header">
  <div class="container">
    <h2><%= sectionHeader.title %></h2>
    <p><%= sectionHeader.subtitle %></p>
  </div>
</div>

<!-- Research Cards -->
<div class="research-cards">
  <div class="container">
    <% researchItems.forEach(function(item) { %>
    <a href="<%= item.href || '#' %>" class="research-card">
      <div class="research-card-image">
        <% if (item.darkImage) { %>
        <img class="img-light" src="<%= item.image %>" alt="<%= item.title %>">
        <img class="img-dark" src="<%= item.darkImage %>" alt="<%= item.title %>">
        <% } else { %>
        <img src="<%= item.image %>" alt="<%= item.title %>">
        <% } %>
      </div>
      <div class="research-card-text">
        <h3><%= item.title %></h3>
        <p><%= item.description %></p>
        <span class="read-more">Read more &rarr;</span>
      </div>
    </a>
    <% }) %>
  </div>
</div>

<!-- Build with SDK -->
<div class="sdk-section">
  <div class="container">
    <div class="sdk-inner">
      <div class="sdk-text">
        <h2><%= cta.title %></h2>
        <p><%= cta.description %></p>
        <a href="<%= cta.buttonUrl %>" target="_blank" rel="noopener noreferrer" class="sdk-cta"><%= cta.buttonLabel %> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg></a>
      </div>
      <div class="sdk-image">
        <% if (cta.darkImage) { %>
        <img class="img-light" src="<%= cta.image %>" alt="<%= cta.title %>">
        <img class="img-dark" src="<%= cta.darkImage %>" alt="<%= cta.title %>">
        <% } else { %>
        <img src="<%= cta.image %>" alt="<%= cta.title %>">
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

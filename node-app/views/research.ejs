<%- include('partials/head') %>
<%- include('partials/header') %>

<!-- Animated Blobs -->
<div class="blobs-container">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
</div>

<!-- Research Hero -->
<div class="research-hero">
  <div class="container">
    <div class="research-hero-title">
      <h1>Exploring the Research Behind Hax</h1>
    </div>
    <div class="research-hero-inner">
      <div class="research-hero-text">
        <p>The HAX Research Laboratory is a design research initiative focused on exploring the foundational principles of Human-Agent Collaboration. We provide essential empirical and conceptual understanding, insights, and frameworks to help designers and innovators shape intuitive and effective Human-Agent interactions for the emerging Internet of Agents.</p>
      </div>
      <div class="research-hero-image">
        <img src="/images/research/hero.png" alt="Hax Research">
      </div>
    </div>
  </div>
</div>

<!-- Section Title -->
<div class="research-section-header">
  <div class="container">
    <h2>Advancing the Science of Human Agent Interaction</h2>
    <p>Investigating how humans and agents think, act, and build together</p>
  </div>
</div>

<!-- Research Cards -->
<div class="research-cards">
  <div class="container">
    <% researchItems.forEach(function(item) { %>
    <div class="research-card">
      <div class="research-card-image">
        <img src="<%= item.image %>" alt="<%= item.title %>">
      </div>
      <div class="research-card-text">
        <h3><%= item.title %></h3>
        <p><%= item.description %></p>
        <a href="#" class="read-more">Read more &rarr;</a>
      </div>
    </div>
    <% }) %>
  </div>
</div>

<!-- Build with SDK -->
<div class="sdk-section">
  <div class="container">
    <div class="sdk-inner">
      <div class="sdk-text">
        <h2>Build with the Hax SDK</h2>
        <p>The HAX SDK gives developers everything they need to integrate agents into their apps, without losing clarity, structure, or control. Use structured schemas, prebuilt components, and clear boundaries to keep agent behavior collaborative and predictable.</p>
        <a href="#"><button>Explore the SDK</button></a>
      </div>
      <div class="sdk-image">
        <img src="/images/research/sdk-hero.png" alt="Hax SDK">
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

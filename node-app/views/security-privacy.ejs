<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/blobs') %>

<!-- Page Hero -->
<div class="page-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="/research">Research</a> <span>/</span> <a href="/research">Hax</a> <span>/</span> Security &amp; Privacy
    </div>
    <div class="page-hero-title">
      <h1><%= pageData.hero.title %></h1>
    </div>
    <div class="page-hero-inner">
      <div class="page-hero-text">
        <p><%= pageData.hero.description %></p>
      </div>
      <div class="page-hero-image">
        <% if (pageData.heroDarkImage) { %>
        <img class="img-light" src="<%= pageData.heroImage %>" alt="Security &amp; Privacy">
        <img class="img-dark" src="<%= pageData.heroDarkImage %>" alt="Security &amp; Privacy">
        <% } else { %>
        <img src="<%= pageData.heroImage %>" alt="Security &amp; Privacy">
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Building Secure Systems -->
<div class="secure-systems-section">
  <div class="container">
    <div class="secure-systems-header">
      <h2><%= pageData.secureSystemsTitle %></h2>
    </div>

    <div class="secure-cards-grid">
      <% pageData.secureCards.forEach(function(card) { %>
      <div class="secure-card">
        <h3><%= card.title %></h3>
        <p><%= card.description %></p>
      </div>
      <% }) %>
    </div>

    <div class="key-questions">
      <h3><%= pageData.keyQuestionsTitle %></h3>
      <ul>
        <% pageData.keyQuestions.forEach(function(q) { %>
        <li><%= q %></li>
        <% }) %>
      </ul>
    </div>
  </div>
</div>

<!-- Research Approach -->
<div class="research-approach-section">
  <div class="container">
    <div class="research-approach-header">
      <h2><%= pageData.researchApproachTitle %></h2>
      <p><%= pageData.researchApproachDescription %></p>
    </div>

    <% pageData.researchItems.forEach(function(item, i) { %>
    <div class="research-item<%= i % 2 === 0 ? ' reversed' : '' %>">
      <% if (i % 2 === 0) { %>
      <div class="research-item-image">
        <% if (item.darkImage) { %>
        <img class="img-light" src="<%= item.image %>" alt="<%= item.imageAlt || item.title %>">
        <img class="img-dark" src="<%= item.darkImage %>" alt="<%= item.imageAlt || item.title %>">
        <% } else { %>
        <img src="<%= item.image %>" alt="<%= item.imageAlt || item.title %>">
        <% } %>
      </div>
      <% } %>
      <div class="research-item-text">
        <h3><%= item.title %></h3>
        <p><%= item.description %></p>
        <p><strong>We Explore</strong></p>
        <ul>
          <% item.exploreBullets.forEach(function(b) { %>
          <li><%= b %></li>
          <% }) %>
        </ul>
      </div>
      <% if (i % 2 !== 0) { %>
      <div class="research-item-image">
        <% if (item.darkImage) { %>
        <img class="img-light" src="<%= item.image %>" alt="<%= item.imageAlt || item.title %>">
        <img class="img-dark" src="<%= item.darkImage %>" alt="<%= item.imageAlt || item.title %>">
        <% } else { %>
        <img src="<%= item.image %>" alt="<%= item.imageAlt || item.title %>">
        <% } %>
      </div>
      <% } %>
    </div>
    <% }) %>

    <!-- Use Cases -->
    <div class="use-cases">
      <p class="use-cases-label">Use Cases</p>
      <div class="blog-cards">
        <% pageData.useCases.forEach(function(uc) { %>
        <div class="blog-card">
          <div>
            <div class="blog-meta">
              <% uc.tags.forEach(function(tag) { %>
              <span><%= tag %></span>
              <% }) %>
            </div>
            <h4><%- uc.title %></h4>
            <p class="blog-desc"><%= uc.description %></p>
          </div>
          <div></div>
        </div>
        <% }) %>
      </div>
    </div>

  </div>
</div>

<!-- Build with SDK -->
<div class="sdk-section">
  <div class="container">
    <div class="sdk-inner">
      <div class="sdk-text">
        <h2><%= pageData.sdk.title %></h2>
        <p><%= pageData.sdk.description %></p>
        <a href="<%= pageData.sdk.buttonUrl %>" target="_blank" rel="noopener noreferrer" class="sdk-cta"><%= pageData.sdk.buttonLabel %> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg></a>
      </div>
      <div class="sdk-image">
        <% if (pageData.sdk.darkImage) { %>
        <img class="img-light" src="<%= pageData.sdk.image %>" alt="Hax SDK">
        <img class="img-dark" src="<%= pageData.sdk.darkImage %>" alt="Hax SDK">
        <% } else { %>
        <img src="<%= pageData.sdk.image %>" alt="Hax SDK">
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

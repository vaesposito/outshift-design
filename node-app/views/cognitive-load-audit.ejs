<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/blobs') %>

<!-- Page Hero -->
<div class="page-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Home</a> <span>/</span> <a href="/research">Research</a> <span>/</span> <a href="/research/societal-impact">Societal Impact</a> <span>/</span> Cognitive Load Audit
    </div>
    <div class="page-hero-title">
      <h1><%= pageData.hero.title %></h1>
    </div>
    <div class="page-hero-inner">
      <div class="page-hero-text">
        <p><%= pageData.hero.description %></p>
      </div>
      <div class="page-hero-image">
        <% if (pageData.heroDarkImage) { %>
        <img class="img-light" src="<%= pageData.heroImage %>" alt="<%= pageData.hero.title %>">
        <img class="img-dark" src="<%= pageData.heroDarkImage %>" alt="<%= pageData.hero.title %>">
        <% } else { %>
        <img src="<%= pageData.heroImage %>" alt="<%= pageData.hero.title %>">
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Cognitive Load Audit Template -->
<div class="template-section">
  <div class="container">
    <div class="template-header">
      <h2><%= pageData.templateTitle %></h2>
    </div>
    <p class="template-subtitle"><%= pageData.templateSubtitle %></p>

    <% pageData.steps.forEach(function(step, idx) { %>
    <div class="template-content">
      <div class="template-text-col">
        <div class="template-block">
          <h3>Instructions</h3>
          <ol>
            <% step.instructions.forEach(function(inst) { %>
            <li><%= inst %></li>
            <% }) %>
          </ol>
        </div>
        <div class="template-block">
          <h3>Methodology</h3>
          <p><%= step.methodology %></p>
        </div>
      </div>
      <div class="template-diagram">
        <% if (step.diagramDark) { %>
        <img class="img-light" src="<%= step.diagram %>" alt="<%= step.title %>">
        <img class="img-dark" src="<%= step.diagramDark %>" alt="<%= step.title %>">
        <% } else { %>
        <img src="<%= step.diagram %>" alt="<%= step.title %>">
        <% } %>
      </div>
    </div>
    <% }) %>

    <% if (pageData.importanceNote) { %>
    <div class="template-block" style="margin-top: 32px;">
      <p><strong>Importance:</strong> <%= pageData.importanceNote %></p>
    </div>
    <% } %>
  </div>
</div>


<%- include('partials/footer') %>

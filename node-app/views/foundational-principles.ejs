<%- include('partials/head') %>
<%- include('partials/header') %>

<!-- Animated Blobs -->
<%- include('partials/blobs') %>

<!-- Page Hero -->
<div class="page-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Home</a> <span>/</span> <a href="/research">Research</a> <span>/</span> Foundational Principles
    </div>
    <div class="page-hero-title">
      <h1><%= pageData.hero.title %></h1>
    </div>
    <div class="page-hero-inner">
      <div class="page-hero-text">
        <p><%= pageData.hero.description %></p>
      </div>
      <div class="page-hero-image">
        <% if (pageData.heroDarkImage) { %>
        <img class="img-light" src="<%= pageData.heroImage %>" alt="<%= pageData.hero.title %>">
        <img class="img-dark" src="<%= pageData.heroDarkImage %>" alt="<%= pageData.hero.title %>">
        <% } else { %>
        <img src="<%= pageData.heroImage %>" alt="<%= pageData.hero.title %>">
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Research to Design Pipeline -->
<div class="pipeline-section">
  <div class="container">
    <div class="pipeline-header">
      <h2><%= pageData.pipelineTitle %></h2>
      <p><%= pageData.pipelineSubtitle %></p>
    </div>

    <div class="pipeline-steps">
      <% pageData.steps.forEach(function(step) { %>
      <div class="pipeline-step">
        <div class="step-number"><%= step.stepNumber %></div>
        <div class="step-title"><%- step.title %></div>
        <% if (step.subtitle) { %>
        <div class="step-subtitle"><%= step.subtitle %></div>
        <% } %>
        <p class="step-desc"><%= step.description %></p>
        <% if (step.quote) { %>
        <div class="step-quote"><%- step.quote %></div>
        <% } %>
        <% if (step.bullets && step.bullets.length) { %>
        <ul class="step-list">
          <% step.bullets.forEach(function(b) { %>
          <li><%- b %></li>
          <% }) %>
        </ul>
        <% } %>
        <% if (step.deliverables && step.deliverables.length) { %>
        <div class="step-deliverable">
          <div class="step-deliverable-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg> Deliverable</div>
          <ul class="step-list">
            <% step.deliverables.forEach(function(d) { %>
            <li><%- d %></li>
            <% }) %>
          </ul>
        </div>
        <% } %>
      </div>
      <% }) %>
    </div>
  </div>
</div>

<!-- Case Studies -->
<div class="case-studies">
  <div class="container">
    <div class="case-studies-header">
      <h2><%= pageData.caseStudiesTitle %></h2>
      <p><%= pageData.caseStudiesDescription %></p>
    </div>

    <% pageData.caseStudies.forEach(function(cs, i) { %>
    <div class="case-study-card">
      <p class="case-study-label">Case Study 0<%= i + 1 %></p>
      <h3><%= cs.title %></h3>
      <% if (cs.tags && cs.tags.length) { %>
      <div class="case-study-tags">
        <% cs.tags.forEach(function(t) { %>
        <span><%= t %></span>
        <% }) %>
      </div>
      <% } %>
      <p class="case-study-desc"><%= cs.description %></p>
      <% if (cs.problem) { %>
      <div class="case-study-problem">
        <p class="case-study-problem-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> Problem</p>
        <p><%= cs.problem %></p>
      </div>
      <% } %>
      <% if (cs.principles && cs.principles.length) { %>
      <p class="case-study-principles-label">Design principles applied</p>
      <div class="case-study-themes">
        <% cs.principles.forEach(function(p) { %>
        <span><%= p %></span>
        <% }) %>
      </div>
      <% } %>
    </div>
    <% }) %>

  </div>
</div>


<%- include('partials/footer') %>

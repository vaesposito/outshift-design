<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/blobs') %>

<!-- Page Hero -->
<div class="page-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Home</a> <span>/</span> <a href="/research">Research</a> <span>/</span> Societal Impact
    </div>
    <div class="page-hero-title">
      <h1><%= pageData.hero.title %></h1>
    </div>
    <div class="page-hero-inner">
      <div class="page-hero-text">
        <p><%= pageData.hero.description %></p>
        <% if (pageData.heroListItems && pageData.heroListItems.length) { %>
        <ul>
          <% pageData.heroListItems.forEach(function(item) { %>
          <li><%= item %></li>
          <% }) %>
        </ul>
        <% } %>
      </div>
      <div class="page-hero-image">
        <% if (pageData.heroDarkImage) { %>
        <img class="img-light" src="<%= pageData.heroImage %>" alt="<%= pageData.hero.title %>">
        <img class="img-dark" src="<%= pageData.heroDarkImage %>" alt="<%= pageData.hero.title %>">
        <% } else { %>
        <img src="<%= pageData.heroImage %>" alt="<%= pageData.hero.title %>">
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- A Framework for Responsible Agent Design -->
<div class="framework-section">
  <div class="container">
    <div class="framework-section-header">
      <h2><%= pageData.frameworkTitle %></h2>
      <p><%= pageData.frameworkDescription %></p>
    </div>

    <div class="responsible-steps">
      <% pageData.steps.forEach(function(step) { %>
      <div class="responsible-step" id="<%= step.slug %>">
        <div class="responsible-step-image">
          <% if (step.darkImage) { %>
          <img class="img-light" src="<%= step.image %>" alt="<%= step.imageAlt || step.title %>">
          <img class="img-dark" src="<%= step.darkImage %>" alt="<%= step.imageAlt || step.title %>">
          <% } else { %>
          <img src="<%= step.image %>" alt="<%= step.imageAlt || step.title %>">
          <% } %>
        </div>
        <div class="responsible-step-content">
          <p class="responsible-step-label"><%= step.label %></p>
          <h3><%- step.title %></h3>
          <ul>
            <% step.bullets.forEach(function(b) { %>
            <li><%= b %></li>
            <% }) %>
          </ul>
          <% if (step.templateLabel) { %>
          <div class="responsible-step-template">
            <strong>Templates</strong>
            <% if (step.templateLink && step.templateLink !== '#') { %>
            <a href="<%= step.templateLink %>"><%= step.templateLabel %></a>
            <% } else { %>
            <%= step.templateLabel %>
            <% } %>
          </div>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/blobs') %>

<!-- Page Hero -->
<div class="page-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="/research">Research</a> <span>/</span> <a href="/research">Hax</a> <span>/</span> Societal Impact
    </div>
    <div class="page-hero-title">
      <h1><%= pageData.hero.title %></h1>
    </div>
    <div class="page-hero-inner">
      <div class="page-hero-text">
        <p><%= pageData.hero.description %></p>
        <% if (pageData.heroListItems && pageData.heroListItems.length) { %>
        <ul>
          <% pageData.heroListItems.forEach(function(item) { %>
          <li><%= item %></li>
          <% }) %>
        </ul>
        <% } %>
      </div>
      <div class="page-hero-image">
        <img src="<%= pageData.heroImage %>" alt="<%= pageData.hero.title %>">
      </div>
    </div>
  </div>
</div>

<!-- A Framework for Responsible Agent Design -->
<div class="framework-section">
  <div class="container">
    <div class="framework-section-header">
      <h2><%= pageData.frameworkTitle %></h2>
      <p><%= pageData.frameworkDescription %></p>
    </div>

    <div class="responsible-steps">
      <% pageData.steps.forEach(function(step) { %>
      <div class="responsible-step">
        <div class="responsible-step-image">
          <img src="<%= step.image %>" alt="<%= step.imageAlt || step.title %>">
        </div>
        <div class="responsible-step-content">
          <p class="responsible-step-label"><%= step.label %></p>
          <h3><%- step.title %></h3>
          <ul>
            <% step.bullets.forEach(function(b) { %>
            <li><%= b %></li>
            <% }) %>
          </ul>
          <% if (step.templateLabel) { %>
          <div class="responsible-step-template">
            <strong>Templates</strong>
            <%= step.templateLabel %>
          </div>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</div>

<!-- Build with SDK -->
<div class="sdk-section">
  <div class="container">
    <div class="sdk-inner">
      <div class="sdk-text">
        <h2><%= pageData.sdk.title %></h2>
        <p><%= pageData.sdk.description %></p>
        <a href="<%= pageData.sdk.buttonUrl %>" target="_blank" rel="noopener noreferrer" class="sdk-cta"><%= pageData.sdk.buttonLabel %> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg></a>
      </div>
      <div class="sdk-image">
        <img src="<%= pageData.sdk.image %>" alt="Hax SDK">
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>

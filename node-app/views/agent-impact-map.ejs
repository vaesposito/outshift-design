<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/blobs') %>

<!-- Page Hero -->
<div class="page-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="/research">Research</a> <span>/</span> <a href="/hax">Hax</a> <span>/</span> Agent Impact Map
    </div>
    <div class="page-hero-title">
      <h1><%= pageData.hero.title %></h1>
    </div>
    <div class="page-hero-inner">
      <div class="page-hero-text">
        <p><%= pageData.hero.description %></p>
      </div>
      <div class="page-hero-image">
        <% if (pageData.heroDarkImage) { %>
        <img class="img-light" src="<%= pageData.heroImage %>" alt="<%= pageData.hero.title %>">
        <img class="img-dark" src="<%= pageData.heroDarkImage %>" alt="<%= pageData.hero.title %>">
        <% } else { %>
        <img src="<%= pageData.heroImage %>" alt="<%= pageData.hero.title %>">
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Agent Impact Map Template -->
<div class="template-section">
  <div class="container">
    <div class="template-header">
      <h2><%= pageData.templateTitle %></h2>
    </div>
    <p class="template-subtitle"><%= pageData.templateSubtitle %></p>

    <div class="template-content">
      <div class="template-text-col">
        <div class="template-block">
          <h3>Instructions</h3>
          <ol>
            <% pageData.instructions.forEach(function(inst) { %>
            <li><%= inst %></li>
            <% }) %>
          </ol>
        </div>
        <div class="template-block">
          <h3>Methodology</h3>
          <p><%= pageData.methodology %></p>
        </div>
      </div>
      <div class="template-diagram">
        <% if (pageData.diagramDark) { %>
        <img class="img-light" src="<%= pageData.diagram %>" alt="Agent Impact Map Diagram">
        <img class="img-dark" src="<%= pageData.diagramDark %>" alt="Agent Impact Map Diagram">
        <% } else { %>
        <img src="<%= pageData.diagram %>" alt="Agent Impact Map Diagram">
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Build with SDK -->
<div class="sdk-section">
  <div class="container">
    <div class="sdk-inner">
      <div class="sdk-text">
        <h2><%= pageData.sdk.title %></h2>
        <p><%= pageData.sdk.description %></p>
        <a href="<%= pageData.sdk.buttonUrl %>" target="_blank" rel="noopener noreferrer" class="sdk-cta"><%= pageData.sdk.buttonLabel %> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg></a>
      </div>
      <div class="sdk-image">
        <% if (pageData.sdk.darkImage) { %>
        <img class="img-light" src="<%= pageData.sdk.image %>" alt="Hax SDK">
        <img class="img-dark" src="<%= pageData.sdk.darkImage %>" alt="Hax SDK">
        <% } else { %>
        <img src="<%= pageData.sdk.image %>" alt="Hax SDK">
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

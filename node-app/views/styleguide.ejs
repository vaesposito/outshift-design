<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
<title><%= pageTitle %></title>
<link rel="preconnect" href="https://rsms.me/">
<link rel="stylesheet" href="https://rsms.me/inter/inter.css">
<link rel="stylesheet" href="/css/styleguide.css">
<script>(function(){var t=localStorage.getItem('theme');if(t){document.documentElement.setAttribute('data-theme',t)}else if(window.matchMedia('(prefers-color-scheme: dark)').matches){document.documentElement.setAttribute('data-theme','dark')}})();</script>
</head>
<body>

<div class="sg-container">
  <div class="sg-header">
    <div class="sg-header-inner">
      <div class="logo">
        <a href="/" style="display:flex;align-items:center;">
          <img src="/images/outshift_logo.svg" alt="Outshift" class="logo-light">
          <img src="/images/outshift_logo-white.svg" alt="Outshift" class="logo-dark">
          <span class="design">design</span>
        </a>
      </div>
      <div class="sg-header-right">
        <div class="sg-nav-links">
          <a href="/styleguide">Style Guide</a>
          <a href="/components">Components</a>
        </div>
        <button class="theme-toggle" aria-label="Toggle theme"><svg class="icon-moon" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2.5C9.005 3.495 8.447 4.843 8.447 6.25c0 1.407.559 2.755 1.553 3.75.995.995 2.344 1.553 3.75 1.553 1.407 0 2.755-.558 3.75-1.553 0 1.483-.44 2.933-1.264 4.167-.824 1.233-1.995 2.195-3.366 2.762-1.37.568-2.878.716-4.333.427-1.455-.29-2.791-1.004-3.84-2.053-1.049-1.049-1.763-2.386-2.053-3.84a7.502 7.502 0 0 1 .427-4.334A7.502 7.502 0 0 1 5.833 3.764 7.502 7.502 0 0 1 10 2.5Z" stroke="currentColor" stroke-width="1.667" stroke-linecap="round" stroke-linejoin="round"/></svg><svg class="icon-sun" width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="3.333" stroke="currentColor" stroke-width="1.667"/><path d="M10 1.667V3.333M10 16.667V18.333M3.517 3.517l1.178 1.178M15.305 15.305l1.178 1.178M1.667 10H3.333M16.667 10H18.333M3.517 16.483l1.178-1.178M15.305 4.695l1.178-1.178" stroke="currentColor" stroke-width="1.667" stroke-linecap="round"/></svg></button>
      </div>
    </div>
  </div>
</div>

<div class="sg-container">

  <!-- COLOR PALETTE -->
  <div class="sg-section">
    <p class="sg-section-title">Foundation</p>
    <h2 class="sg-section-heading">Color Palette</h2>
    <p class="sg-section-desc">The Outshift Design color system is built on a neutral, professional base with strategic accent colors for emphasis and interaction.</p>

    <p class="sg-component-label" style="margin-top:32px;">Light Mode — Primary Colors</p>
    <div class="sg-colors">
      <% const primaryColors = [
        { name: 'Ink', hex: '#293247', usage: 'Primary text, headings, logo' },
        { name: 'Slate', hex: '#67707F', usage: 'Body text, descriptions' },
        { name: 'Stone', hex: '#59616B', usage: 'Captions, metadata, labels' },
        { name: 'White', hex: '#FFFFFF', usage: 'Page background, cards' },
      ] %>
      <% primaryColors.forEach(c => { %>
      <div class="sg-color-card">
        <div class="sg-color-swatch" style="background:<%= c.hex %>;<%= c.hex === '#FFFFFF' ? ' border-bottom:1px solid rgba(41,50,71,0.08);' : '' %>"></div>
        <div class="sg-color-info">
          <p class="sg-color-name"><%= c.name %></p>
          <p class="sg-color-hex"><%= c.hex %></p>
          <p class="sg-color-usage"><%= c.usage %></p>
        </div>
      </div>
      <% }) %>
    </div>

    <p class="sg-component-label" style="margin-top:40px;">Dark Mode — Primary Colors</p>
    <div class="sg-colors">
      <% const darkColors = [
        { name: 'Void', hex: '#0f1117', usage: 'Page background' },
        { name: 'Snow', hex: '#e0e4ec', usage: 'Primary text, headings' },
        { name: 'Fog', hex: '#9ca3b0', usage: 'Body text, descriptions' },
        { name: 'Ash', hex: '#8a919c', usage: 'Captions, metadata, labels' },
      ] %>
      <% darkColors.forEach(c => { %>
      <div class="sg-color-card">
        <div class="sg-color-swatch" style="background:<%= c.hex %>;"></div>
        <div class="sg-color-info">
          <p class="sg-color-name"><%= c.name %></p>
          <p class="sg-color-hex"><%= c.hex %></p>
          <p class="sg-color-usage"><%= c.usage %></p>
        </div>
      </div>
      <% }) %>
    </div>

    <p class="sg-component-label" style="margin-top:40px;">Accent Colors</p>
    <div class="sg-colors">
      <% const accentColors = [
        { name: 'Cyan', hex: '#00BCEB', usage: 'Links, CTAs, interactive' },
        { name: 'Blue', hex: '#187ADC', usage: 'Hover states, active links' },
        { name: 'Violet', hex: '#9345E1', usage: 'Gradient accent, cursor' },
        { name: 'Lavender', hex: '#D2C2FF', usage: 'Section backgrounds (15% alpha)' },
      ] %>
      <% accentColors.forEach(c => { %>
      <div class="sg-color-card">
        <div class="sg-color-swatch" style="background:<%= c.hex %>;"></div>
        <div class="sg-color-info">
          <p class="sg-color-name"><%= c.name %></p>
          <p class="sg-color-hex"><%= c.hex %></p>
          <p class="sg-color-usage"><%= c.usage %></p>
        </div>
      </div>
      <% }) %>
    </div>

    <p class="sg-component-label" style="margin-top:40px;">Brand Gradient</p>
    <div class="sg-colors">
      <% const gradientColors = [
        { name: 'Green', hex: '#74BF4B' },
        { name: 'Amber', hex: '#F5B35C' },
        { name: 'Orange', hex: '#F09256' },
        { name: 'Coral', hex: '#EB7251' },
      ] %>
      <% gradientColors.forEach(c => { %>
      <div class="sg-color-card">
        <div class="sg-color-swatch" style="background:<%= c.hex %>;"></div>
        <div class="sg-color-info">
          <p class="sg-color-name"><%= c.name %></p>
          <p class="sg-color-hex"><%= c.hex %></p>
        </div>
      </div>
      <% }) %>
    </div>

    <p class="sg-component-label" style="margin-top:40px;">Gradients</p>
    <p class="sg-gradient-label">Brand Gradient (button borders)</p>
    <div class="sg-gradient-bar" style="background: linear-gradient(294deg, #9345E1, #187ADC, #00BCEB, #74BF4B, #F5B35C, #F09256, #EB7251);"></div>
    <p class="sg-gradient-label" style="margin-top:24px;">SDK CTA Gradient (conic, pill buttons)</p>
    <div class="sg-gradient-bar" style="background: conic-gradient(from 180deg, #ff6b6b, #a855f7, #6366f1, #3b82f6, #00bceb, #10b981, #eab308, #ff6b6b);"></div>
    <p class="sg-gradient-label" style="margin-top:24px;">Card Stroke Gradient (research cards)</p>
    <div class="sg-gradient-bar" style="background: linear-gradient(to right, rgba(77, 99, 128, 0.21), #2268BE);"></div>
    <p class="sg-gradient-label" style="margin-top:24px;">Section Background</p>
    <div class="sg-gradient-bar" style="background: linear-gradient(to right, rgba(210, 194, 255, 0.15), rgba(255, 255, 255, 0)); border: 1px solid rgba(41,50,71,0.08);"></div>

    <p class="sg-component-label" style="margin-top:40px;">Borders &amp; Overlays</p>
    <div class="sg-colors" style="grid-template-columns: repeat(3, 1fr);">
      <% const borderColors = [
        { name: 'Border Light', hex: 'rgba(41, 50, 71, 0.08)', usage: 'Dividers, card borders' },
        { name: 'Border Medium', hex: 'rgba(41, 50, 71, 0.15)', usage: 'Buttons, tags, arrow links' },
        { name: 'Overlay Dark', hex: 'rgba(41, 50, 71, 0.7)', usage: 'Badges, overlays' },
      ] %>
      <% borderColors.forEach(c => { %>
      <div class="sg-color-card">
        <div class="sg-color-swatch" style="background:<%= c.hex %>;"></div>
        <div class="sg-color-info">
          <p class="sg-color-name"><%= c.name %></p>
          <p class="sg-color-hex"><%= c.hex %></p>
          <p class="sg-color-usage"><%= c.usage %></p>
        </div>
      </div>
      <% }) %>
    </div>
  </div>

  <hr class="sg-divider">

  <!-- TYPOGRAPHY -->
  <div class="sg-section">
    <p class="sg-section-title">Foundation</p>
    <h2 class="sg-section-heading">Typography</h2>
    <p class="sg-section-desc">Inter Variable is used across all weights. The type scale pairs light display headings with semibold emphasis for visual hierarchy.</p>

    <p class="sg-component-label">Typeface</p>
    <div style="font-size: 3em; font-weight: 200; margin-bottom: 4px;">Inter Variable</div>
    <div style="font-size: 1em; color: var(--color-text-subtle); margin-bottom: 40px; font-family: 'SF Mono', 'Fira Code', monospace;">font-family: InterVariable, sans-serif</div>

    <p class="sg-component-label">Font Weights</p>
    <div class="sg-weights">
      <% const weights = [
        { label: 'Extra Light', value: 200 },
        { label: 'Regular', value: 400 },
        { label: 'Medium', value: 500 },
        { label: 'Semibold', value: 600 },
        { label: 'Bold', value: 700 },
        { label: 'Extra Bold', value: 800 },
      ] %>
      <% weights.forEach(w => { %>
      <div class="sg-weight-card">
        <div class="sg-weight-sample" style="font-weight:<%= w.value %>;">Aa</div>
        <div class="sg-weight-label"><%= w.label %></div>
        <div class="sg-weight-value"><%= w.value %></div>
      </div>
      <% }) %>
    </div>

    <p class="sg-component-label" style="margin-top:48px;">Type Scale</p>

    <% const typeScale = [
      { tag: '<h1>', cls: 'demo-h1', specs: '4em / 64px | Weight 200 | Color: #293247', sample: 'Display Light', el: 'h1' },
      { tag: '<h2>', cls: 'demo-h2', specs: '4em / 64px | Weight 600 | Color: #293247', sample: 'Display Bold', el: 'h2' },
      { tag: '<h3>', cls: 'demo-h3', specs: '3em / 48px | Weight 200 | Color: #293247', sample: 'Section Heading', el: 'h3' },
      { tag: '<h4>', cls: 'demo-h4', specs: '1.2em / 19px | Weight 600 | Color: #67707F', sample: 'Subtitle — used for section descriptions and supporting text beneath headings', el: 'h4' },
      { tag: '<h5>', cls: 'demo-h5', specs: '1.5em / 24px | Weight 200 | Line-height: 1.6 | Color: #293247', sample: 'Lead paragraph — used for hero introductions and prominent body copy that requires extra emphasis.', el: 'h5' },
      { tag: '<h6>', cls: 'demo-h6', specs: '0.8em / 13px | Weight 600 | Uppercase | Tracking: 1.8px | Color: #59616B', sample: 'Overline Label', el: 'h6' },
      { tag: '<p> body', cls: 'demo-body', specs: '1.05em / 17px | Weight 400 | Line-height: 1.6 | Color: #67707F', sample: 'Body text is used for descriptions, card content, and general reading. It provides comfortable readability with generous line-height.', el: 'p' },
      { tag: '<small> caption', cls: 'demo-caption', specs: '0.85em / 14px | Weight 400 | Color: #59616B', sample: 'Caption and metadata text — timestamps, reading time, copyright notices.', el: 'p' },
    ] %>
    <% typeScale.forEach((t, i) => { %>
    <div class="sg-type-row"<%= i === typeScale.length - 1 ? ' style="border-bottom:none;"' : '' %>>
      <div class="sg-type-meta">
        <div class="sg-type-tag"><%= t.tag %></div>
        <div class="sg-type-specs"><%- t.specs.split(' | ').join('<br>') %></div>
      </div>
      <div class="sg-type-sample">
        <<%= t.el %> class="<%= t.cls %>"><%= t.sample %></<%= t.el %>>
      </div>
    </div>
    <% }) %>
  </div>

  <hr class="sg-divider">

  <!-- COMPONENTS -->
  <div class="sg-section">
    <p class="sg-section-title">Components</p>
    <h2 class="sg-section-heading">UI Elements</h2>
    <p class="sg-section-desc">Reusable components used across the Outshift Design site, from buttons and badges to interactive link elements.</p>

    <div class="sg-component-grid">
      <div class="sg-component-card">
        <p class="sg-component-label">Primary Button (Brand Gradient)</p>
        <div class="sg-component-demo" style="gap:20px;">
          <button class="demo-btn">See Our Work</button>
          <button class="demo-btn demo-btn-sm">View All Articles</button>
        </div>
        <p class="demo-caption" style="margin-top:16px;">Gradient border via mask composite. Padding: 18px 24px. Radius: 40px.</p>
      </div>

      <div class="sg-component-card">
        <p class="sg-component-label">SDK CTA (Conic Gradient)</p>
        <div class="sg-component-demo">
          <button class="demo-sdk-cta">Explore the SDK <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg></button>
        </div>
        <p class="demo-caption" style="margin-top:16px;">Conic gradient border. Padding: 14px 28px. Radius: 999px. Scale 1.03 on hover.</p>
      </div>

      <div class="sg-component-card">
        <p class="sg-component-label">Badges</p>
        <div class="sg-component-demo">
          <span class="demo-badge">SDK</span>
          <span class="demo-badge">AI/ML</span>
          <span class="demo-badge">Research</span>
        </div>
        <p class="demo-caption" style="margin-top:16px;">Overlay dark bg, white text, uppercase. Radius: 6px. Backdrop blur: 8px.</p>
      </div>

      <div class="sg-component-card">
        <p class="sg-component-label">Tags</p>
        <div class="sg-component-demo">
          <a href="#" class="demo-tag" onclick="return false;">AI Agents</a>
          <a href="#" class="demo-tag" onclick="return false;">Design Systems</a>
          <a href="#" class="demo-tag" onclick="return false;">Connectivity</a>
        </div>
        <p class="demo-caption" style="margin-top:16px;">Pill-shaped with cyan bg/border. Radius: 20px. Padding: 6px 16px.</p>
      </div>

      <div class="sg-component-card">
        <p class="sg-component-label">Arrow Links</p>
        <div class="sg-component-demo" style="gap:20px;">
          <a href="#" class="demo-arrow-link" onclick="return false;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
          </a>
          <a href="#" class="demo-read-more" onclick="return false;">Read more</a>
        </div>
        <p class="demo-caption" style="margin-top:16px;">40&times;40px icon button (radius 10px) and inline text link (#00BCEB).</p>
      </div>

      <div class="sg-component-card">
        <p class="sg-component-label">Social Icons</p>
        <div class="demo-social-icons">
          <a href="#" onclick="return false;" aria-label="X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
          <a href="#" onclick="return false;" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
          <a href="#" onclick="return false;" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
        </div>
        <p class="demo-caption" style="margin-top:16px;">40&times;40px with border, radius 10px. Hover: bg + color shift.</p>
      </div>
    </div>
  </div>

  <hr class="sg-divider">

  <!-- CARD STYLES -->
  <div class="sg-section">
    <p class="sg-section-title">Components</p>
    <h2 class="sg-section-heading">Card Styles</h2>
    <p class="sg-section-desc">Cards used throughout the site in various contexts: blog, research, use cases, and content sections.</p>

    <p class="sg-component-label">Secure Card / Template Block</p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:32px;">
      <div class="demo-secure-card">
        <h3>Card Title</h3>
        <p>Card description text with purple gradient background. Used for "Building Secure Systems" and template instruction blocks.</p>
      </div>
      <div class="demo-secure-card">
        <h3>Another Card</h3>
        <p>Same visual treatment for content blocks across research pages. Font: 1.4em/500 title, 0.95em body.</p>
      </div>
    </div>
    <p class="demo-caption">Background: --color-blog-card-bg. Padding: 32px. Radius: 12px. Border: 1px solid --color-border.</p>

    <p class="sg-component-label" style="margin-top:40px;">Blog Card / Use Case Card</p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:32px;">
      <div class="demo-blog-card">
        <div>
          <h4>The Future of Design Systems</h4>
          <p class="blog-desc">How we built a scalable design system that powers hundreds of products across the enterprise.</p>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;font-size:0.85em;color:var(--color-text-subtle);margin-top:16px;">
          <span>5 min read</span>
          <a href="#" class="demo-read-more" onclick="return false;">Read more</a>
        </div>
      </div>
      <div class="demo-blog-card">
        <div>
          <h4>Agent-Driven Workflows</h4>
          <p class="blog-desc">Exploring how autonomous agents can streamline complex multi-step processes with human oversight.</p>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;font-size:0.85em;color:var(--color-text-subtle);margin-top:16px;">
          <span>8 min read</span>
          <a href="#" class="demo-read-more" onclick="return false;">Read more</a>
        </div>
      </div>
    </div>
    <p class="demo-caption">Background: --color-blog-card-bg. Padding: 40px. Radius: 16px. Hover: translateY(-4px) + shadow.</p>

    <p class="sg-component-label" style="margin-top:40px;">Research Card</p>
    <div class="sg-research-card-demo">
      <div class="sg-demo-rcard">
        <div class="sg-demo-rcard-image">
          <img src="/images/research/foundational-principles.png" alt="Foundational Principles">
        </div>
        <div class="sg-demo-rcard-text">
          <h3>Foundational Principles</h3>
          <p>We build foundational design principles and frameworks for AI-human interaction.</p>
          <a href="#" class="demo-read-more" onclick="return false;">Read more</a>
        </div>
      </div>
    </div>
    <p class="demo-caption" style="margin-top:16px;">Width: 7/12 (58.333%). Padding: 32px. Radius: 20px. Stroke: gradient border via mask composite. Hover: translateY(-4px) + shadow + image scale(1.05).</p>
  </div>

  <hr class="sg-divider">

  <!-- CUSTOM CURSOR -->
  <div class="sg-section">
    <p class="sg-section-title">Components</p>
    <h2 class="sg-section-heading">Custom Cursor</h2>
    <p class="sg-section-desc">A mix-blend-mode: difference cursor that inverts against the background. Scales 2x on interactive elements with a gray border ring.</p>

    <div style="padding:32px; border-radius:16px; border:1px solid var(--color-border); text-align:center;">
      <div style="display:inline-flex; align-items:center; gap:24px;">
        <div style="width:20px; height:20px; border-radius:9999px; background:#fff; mix-blend-mode:difference;"></div>
        <span class="demo-caption">Default (20px)</span>
        <div style="width:40px; height:40px; border-radius:9999px; background:#fff; mix-blend-mode:difference; border:5px solid #b4b4b4;"></div>
        <span class="demo-caption">Hover (scale 2x + border)</span>
      </div>
    </div>
    <p class="demo-caption" style="margin-top:16px;">Size: 20px. Blend: difference. Transition: 0.25s cubic-bezier(0.78, 0, 0.22, 1). Only on pointer: fine devices.</p>
  </div>

  <hr class="sg-divider">

  <!-- SPACING -->
  <div class="sg-section">
    <p class="sg-section-title">Foundation</p>
    <h2 class="sg-section-heading">Spacing &amp; Radius</h2>
    <p class="sg-section-desc">Consistent spacing and border radius values create rhythm and cohesion across the interface.</p>

    <p class="sg-component-label">Spacing Scale</p>
    <% const spacings = [
      { label: 'xs', value: 8 }, { label: 'sm', value: 16 }, { label: 'md', value: 24 },
      { label: 'lg', value: 32 }, { label: 'xl', value: 40 }, { label: '2xl', value: 60 },
      { label: '3xl', value: 80 }, { label: '4xl', value: 110 },
    ] %>
    <% spacings.forEach(s => { %>
    <div class="sg-spacing-row">
      <span class="sg-spacing-label"><%= s.label %></span>
      <div class="sg-spacing-bar" style="width:<%= s.value %>px;"></div>
      <span class="sg-spacing-value"><%= s.value %>px</span>
    </div>
    <% }) %>

    <p class="sg-component-label" style="margin-top:48px;">Container</p>
    <div class="sg-spacing-row">
      <span class="sg-spacing-label">padding</span>
      <div class="sg-spacing-bar" style="width:100px; position:relative;"><span style="position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); font-size:0.7em; color:var(--color-text-subtle); white-space:nowrap;">0 10%</span></div>
      <span class="sg-spacing-value">0 10%</span>
    </div>
    <p class="demo-caption" style="margin-top:4px;">Content container uses percentage-based horizontal padding for responsive scaling.</p>

    <p class="sg-component-label" style="margin-top:48px;">Border Radius</p>
    <div class="sg-radius-grid">
      <% [6, 8, 10, 12, 16, 20, 40, 999].forEach(r => { %>
      <div class="sg-radius-card" style="border-radius:<%= r %>px;"><%= r === 999 ? 'pill' : r + 'px' %></div>
      <% }) %>
    </div>
  </div>

  <hr class="sg-divider">

  <!-- USAGE EXAMPLES -->
  <div class="sg-section">
    <p class="sg-section-title">Patterns</p>
    <h2 class="sg-section-heading">Usage Examples</h2>
    <p class="sg-section-desc">How typography and color combine in context across the site.</p>

    <p class="sg-component-label">Hero Pairing</p>
    <div style="padding:40px 0 48px;">
      <h1 class="demo-h1" style="margin:0;">Design evolves fast</h1>
      <h2 class="demo-h2" style="margin:4px 0 0;">We evolve faster</h2>
    </div>

    <p class="sg-component-label">Section Header Pattern</p>
    <div style="text-align:center; padding:32px 0 48px;">
      <h6 class="demo-h6">Initiatives</h6>
      <h3 class="demo-h3" style="margin:8px 0 12px;">Featured Initiatives</h3>
      <h4 class="demo-h4" style="max-width:500px; margin:0 auto;">Explore our recent projects and see how we're shaping the future of enterprise software.</h4>
    </div>

    <p class="sg-component-label">Page Hero (Research Pages)</p>
    <div style="text-align:center; padding:32px 0 16px;">
      <h1 style="font-size:3.5em; font-weight:600; margin:0; line-height:1.15;">Research Page Title</h1>
    </div>
    <div style="display:flex; gap:40px; align-items:center; padding-bottom:48px;">
      <div style="flex:5;">
        <p style="font-size:18px; font-weight:300; color:var(--color-text-muted); line-height:1.7; margin:0;">A description paragraph that introduces the research topic. It uses 18px/300 weight for a clean, readable feel.</p>
      </div>
      <div style="flex:7;">
        <div style="height:200px; border-radius:16px; background:var(--color-preview-bg); border:1px solid var(--color-border); display:flex; align-items:center; justify-content:center; color:var(--color-text-muted); font-size:0.85em;">Hero Image (525px height)</div>
      </div>
    </div>

    <p class="sg-component-label">Card on Gradient Background</p>
    <div class="sg-dark-preview">
      <div style="background:var(--color-bg); border-radius:16px; border:1px solid var(--color-border); padding:40px; max-width:380px;">
        <h4 style="font-size:24px; font-weight:500; color:var(--color-text); margin:0 0 20px; line-height:1.3;">The Future of Design Systems</h4>
        <p class="demo-body" style="margin:0 0 24px;">How we built a scalable design system that powers hundreds of products.</p>
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <span class="demo-caption">5 min read</span>
          <a href="#" class="demo-read-more" onclick="return false;">Read more</a>
        </div>
      </div>
    </div>
  </div>

</div>

<div style="border-top:1px solid var(--color-border); padding:24px 0; text-align:center; color:var(--color-text-subtle); font-size:0.85em; margin-top:40px;">
  Outshift Design Style Guide &middot; &copy; <%= year %> Outshift by Cisco
</div>

<script>
(function () {
    var saved = localStorage.getItem('theme');
    if (saved) {
        document.documentElement.setAttribute('data-theme', saved);
    } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.setAttribute('data-theme', 'dark');
    }
    document.querySelector('.theme-toggle').addEventListener('click', function () {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        var next = isDark ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
    });
})();
</script>
</body>
</html>

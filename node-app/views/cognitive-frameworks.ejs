<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/blobs') %>

<!-- Page Hero -->
<div class="page-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Home</a> <span>/</span> <a href="/research">Research</a> <span>/</span> Cognitive Frameworks
    </div>
    <div class="page-hero-title">
      <h1><%= pageData.hero.title %></h1>
    </div>
    <div class="page-hero-inner">
      <div class="page-hero-text">
        <p><%= pageData.hero.description %></p>
      </div>
      <div class="page-hero-image">
        <% if (pageData.heroDarkImage) { %>
        <img class="img-light" src="<%= pageData.heroImage %>" alt="<%= pageData.hero.title %>">
        <img class="img-dark" src="<%= pageData.heroDarkImage %>" alt="<%= pageData.hero.title %>">
        <% } else { %>
        <img src="<%= pageData.heroImage %>" alt="<%= pageData.hero.title %>">
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Theoretical Foundations -->
<div class="pipeline-section">
  <div class="container">
    <div class="pipeline-header">
      <h2><%= pageData.theoreticalTitle %></h2>
      <p><%= pageData.theoreticalDescription %></p>
    </div>

    <nav class="pipeline-stepper" aria-label="Theoretical foundations">
      <ol>
        <% pageData.steps.forEach(function(step) { %>
        <li><a href="#cf-step-<%= step.number %>"><span class="pipeline-stepper-num"><%= step.number %></span> <%= step.title %></a></li>
        <% }) %>
      </ol>
    </nav>

    <div class="pipeline-steps pipeline-steps--fullwidth">

      <% pageData.steps.forEach(function(step) { %>
      <div class="pipeline-step" id="cf-step-<%= step.number %>">
        <div class="framework-content">
          <div class="framework-left">
            <div class="step-number"><%= step.number %></div>
            <div class="step-title"><%= step.title %></div>
            <p class="step-desc"><%= step.description %></p>
            <div class="framework-concepts">
              <p class="framework-concepts-title">Key Concepts</p>
              <ul class="step-list" style="margin-bottom:0;">
                <% step.keyConcepts.forEach(function(kc) { %>
                <li><%= kc %></li>
                <% }) %>
              </ul>
            </div>
            <% if (step.whyPosition === 'inside') { %>
            <div class="framework-why">
              <p class="framework-why-title"><%= step.whyTitle %></p>
              <p><%= step.whyText %></p>
            </div>
            <% } %>
          </div>
          <div class="framework-right">
            <div class="framework-collab-box">
              <h4 class="framework-collab-title"><%= step.frameworkTitle %></h4>
              <p class="framework-collab-desc"><%= step.frameworkDescription %></p>
              <% if (step.approachCards) { %>
              <div class="framework-approaches-cards">
                <% step.frameworkImages.forEach(function(img, j) { %>
                <% if (step.frameworkDarkImages && step.frameworkDarkImages[j]) { %>
                <img src="<%= img %>" alt="<%= step.frameworkImageAlts[j] || '' %>" class="framework-approach-svg img-light">
                <img src="<%= step.frameworkDarkImages[j] %>" alt="<%= step.frameworkImageAlts[j] || '' %>" class="framework-approach-svg img-dark">
                <% } else { %>
                <img src="<%= img %>" alt="<%= step.frameworkImageAlts[j] || '' %>" class="framework-approach-svg">
                <% } %>
                <% }) %>
              </div>
              <% } else if (step.frameworkImages.length === 1) { %>
              <% if (step.frameworkDarkImages && step.frameworkDarkImages[0]) { %>
              <img src="<%= step.frameworkImages[0] %>" alt="<%= step.frameworkImageAlts[0] || '' %>" class="framework-diagram img-light">
              <img src="<%= step.frameworkDarkImages[0] %>" alt="<%= step.frameworkImageAlts[0] || '' %>" class="framework-diagram img-dark">
              <% } else { %>
              <img src="<%= step.frameworkImages[0] %>" alt="<%= step.frameworkImageAlts[0] || '' %>" class="framework-diagram">
              <% } %>
              <% } else { %>
              <% if (step.frameworkDarkImages && step.frameworkDarkImages[0]) { %>
              <img src="<%= step.frameworkImages[0] %>" alt="<%= step.frameworkImageAlts[0] || '' %>" class="framework-diagram img-light">
              <img src="<%= step.frameworkDarkImages[0] %>" alt="<%= step.frameworkImageAlts[0] || '' %>" class="framework-diagram img-dark">
              <% } else { %>
              <img src="<%= step.frameworkImages[0] %>" alt="<%= step.frameworkImageAlts[0] || '' %>" class="framework-diagram">
              <% } %>
              <% if (step.coreTitle) { %>
              <h5 class="framework-core-title"><%= step.coreTitle %></h5>
              <% } %>
              <% if (step.frameworkDarkImages && step.frameworkDarkImages[1]) { %>
              <img src="<%= step.frameworkImages[1] %>" alt="<%= step.frameworkImageAlts[1] || '' %>" class="framework-core-svg img-light">
              <img src="<%= step.frameworkDarkImages[1] %>" alt="<%= step.frameworkImageAlts[1] || '' %>" class="framework-core-svg img-dark">
              <% } else { %>
              <img src="<%= step.frameworkImages[1] %>" alt="<%= step.frameworkImageAlts[1] || '' %>" class="framework-core-svg">
              <% } %>
              <% } %>
            </div>
          </div>
        </div>
        <% if (step.whyPosition === 'outside') { %>
        <div class="framework-why">
          <p class="framework-why-title"><%= step.whyTitle %></p>
          <p><%= step.whyText %></p>
        </div>
        <% } %>
        <% if (step.useCases && step.useCases.length) { %>
        <p class="use-cases-label">USE CASES</p>
        <div class="use-cases-grid">
          <% step.useCases.forEach(function(uc) { %>
          <a href="#" class="use-case-card">
            <div>
              <span class="use-case-tag"><%= uc.tag %></span>
              <h4><%= uc.title %></h4>
              <p class="use-case-desc"><%= uc.description %></p>
            </div>
            <% if (uc.author) { %>
            <div class="use-case-meta">
              <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> <%= uc.author %>&nbsp;&nbsp;&nbsp;<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> <%= uc.date %></span>
            </div>
            <% } %>
            <div class="use-case-footer">
              <span><% if (uc.readTime) { %><%= uc.readTime %><% } else { %>Case Study<% } %></span>
              <span class="read-more">Read more &rarr;</span>
            </div>
          </a>
          <% }) %>
        </div>
        <% } %>
      </div>
      <% }) %>

    </div>
  </div>
</div>

<% if (pageData.bannerItems && pageData.bannerItems.length) { %>
<!-- Framework applications banner -->
<div class="cf-banner">
  <div class="container">
    <div class="cf-banner-inner">
      <ul class="cf-banner-list">
        <% pageData.bannerItems.forEach(function(item) { %>
        <li><%= item %></li>
        <% }) %>
      </ul>
    </div>
  </div>
</div>
<% } %>


<script>
// ── Pipeline stepper: scroll-spy + smooth-scroll on click ──
(function () {
    var links = Array.prototype.slice.call(document.querySelectorAll('.pipeline-stepper a[href^="#cf-step-"]'));
    if (!links.length) return;
    var idToLink = {};
    var targets = [];
    links.forEach(function (link) {
        var id = link.getAttribute('href').slice(1);
        var el = document.getElementById(id);
        if (el) { idToLink[id] = link; targets.push(el); }
    });
    if (!targets.length) return;

    function setActive(id) {
        links.forEach(function (a) { a.classList.remove('is-active'); });
        var active = idToLink[id];
        if (active) {
            active.classList.add('is-active');
            try { active.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' }); } catch (e) {}
        }
    }

    if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) setActive(entry.target.id);
            });
        }, { rootMargin: '-30% 0px -55% 0px', threshold: 0 });
        targets.forEach(function (t) { observer.observe(t); });
    }

    links.forEach(function (link) {
        link.addEventListener('click', function (e) {
            var id = link.getAttribute('href').slice(1);
            var el = document.getElementById(id);
            if (!el) return;
            e.preventDefault();
            el.scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.replaceState(null, '', '#' + id);
            setActive(id);
        });
    });
})();
</script>
<%- include('partials/footer') %>

<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/blobs') %>

<!-- Page Hero -->
<div class="page-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="/#initiatives">Initiatives</a> <span>/</span> Hax
    </div>
    <div class="page-hero-title">
      <h1><%= pageData.hero.title %></h1>
    </div>
    <div class="page-hero-inner">
      <div class="page-hero-text">
        <p><%= pageData.hero.description %></p>
        <% if (pageData.heroDescription2) { %>
        <p><%= pageData.heroDescription2 %></p>
        <% } %>
      </div>
      <div class="page-hero-image">
        <video class="video-light" autoplay muted loop playsinline>
          <source src="<%= pageData.heroVideo %>" type="video/mp4">
        </video>
        <% if (pageData.heroDarkVideo) { %>
        <video class="video-dark" autoplay muted loop playsinline>
          <source src="<%= pageData.heroDarkVideo %>" type="video/mp4">
        </video>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Human-Centered AI Patterns -->
<div class="patterns-section">
  <div class="container">
    <div class="patterns-header">
      <h2><%= pageData.patternsTitle %></h2>
      <p><%= pageData.patternsDescription %></p>
    </div>

    <div class="patterns-filters">
      <% pageData.patterns.forEach(function(p, i) { %>
      <button class="pattern-filter<%= i === 0 ? ' is-active' : '' %>" data-pattern="<%= p.key %>"><%= p.title %></button>
      <% }) %>
    </div>

    <% pageData.patterns.forEach(function(p, i) { %>
    <div class="pattern-panel<%= i === 0 ? ' is-active' : '' %>" data-panel="<%= p.key %>">
      <h3 class="pattern-title"><%= p.title %></h3>
      <p class="pattern-desc"><%= p.description %></p>
      <div class="pattern-divider"></div>
      <h4 class="pattern-examples-label">Examples</h4>
      <div class="pattern-visuals">
        <% p.images.forEach(function(img, j) { %>
        <img src="<%= img %>" alt="<%= (p.alts && p.alts[j]) ? p.alts[j] : p.title + ' pattern ' + (j+1) %>">
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>
</div>

<!-- Hax Research -->
<div class="hax-research-section">
  <div class="container">
    <div class="hax-research-inner">
      <div class="hax-research-image">
        <img src="<%= pageData.researchImage %>" alt="Hax research visualization">
      </div>
      <div class="hax-research-text">
        <h2><%= pageData.researchTitle %></h2>
        <p><%= pageData.researchDescription %></p>
        <a href="<%= pageData.researchLink.url %>" class="sdk-cta"<% if (pageData.researchLink.isExternal) { %> target="_blank" rel="noopener noreferrer"<% } %>><%= pageData.researchLink.label %></a>
      </div>
    </div>
  </div>
</div>

<!-- Build with SDK -->
<div class="sdk-section">
  <div class="container">
    <div class="sdk-inner">
      <div class="sdk-text">
        <h2><%= pageData.sdk.title %></h2>
        <p><%= pageData.sdk.description %></p>
        <a href="<%= pageData.sdk.buttonUrl %>" target="_blank" rel="noopener noreferrer" class="sdk-cta"><%= pageData.sdk.buttonLabel %> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg></a>
      </div>
      <div class="sdk-image">
        <% if (pageData.sdk.darkImage) { %>
        <img class="img-light" src="<%= pageData.sdk.image %>" alt="Hax SDK">
        <img class="img-dark" src="<%= pageData.sdk.darkImage %>" alt="Hax SDK">
        <% } else { %>
        <img src="<%= pageData.sdk.image %>" alt="Hax SDK">
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.pattern-filter').forEach(function (btn) {
    btn.addEventListener('click', function () {
        document.querySelectorAll('.pattern-filter.is-active').forEach(function (el) { el.classList.remove('is-active'); });
        btn.classList.add('is-active');
        var target = btn.getAttribute('data-pattern');
        document.querySelectorAll('.pattern-panel').forEach(function (panel) {
            panel.classList.remove('is-active');
        });
        var activePanel = document.querySelector('.pattern-panel[data-panel="' + target + '"]');
        if (activePanel) activePanel.classList.add('is-active');
    });
});
</script>

<%- include('partials/footer') %>

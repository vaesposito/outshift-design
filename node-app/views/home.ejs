<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/blobs') %>
<% var hp = homepage || {}; %>

<!-- Hero -->
<div class="hero-section">
  <div class="container">
    <div class="content">
      <h1><%= hp.heroTitle || 'Design evolves fast' %></h1>
      <h2><%= hp.heroSubtitle || 'We evolve faster' %></h2>
      <h5><%= hp.heroDescription || "Meet the Outshift product design team, Cisco's innovative force for incubation. We specialize in driving ideation and fostering alignment across cross-functional teams." %></h5>
      <p></p>
      <a href="#initiatives" class="cta-button"><%= hp.heroCtaLabel || 'See Our Work' %></a>
    </div>
  </div>
</div>

<!-- Featured Initiatives -->
<div class="initiatives-section" id="initiatives">
  <div class="container">
    <div class="section-header">
      <h3><%= hp.initiativesSectionTitle || 'Featured Initiatives' %></h3>
      <p><%= hp.initiativesSectionSubtitle || "Explore our recent projects and see how we're shaping the future of enterprise software." %></p>
    </div>
  </div>
</div>

<div class="timeline">
  <% initiatives.forEach(card => { %>
  <% var hasInitiativeLink = card.href && card.href !== '#'; %>
  <div class="initiative-card<%= card.reversed ? ' reversed' : '' %><%= hasInitiativeLink ? ' initiative-card--linked' : '' %>">
    <% if (hasInitiativeLink) { %>
    <a href="<%= card.href %>" class="initiative-card-link" aria-label="View initiative: <%= card.title %>"<% if (card.external) { %> target="_blank" rel="noopener noreferrer"<% } %>></a>
    <% } %>
    <div class="card-text">
      <h3><%= card.title %></h3>
      <p><%= card.description %></p>
      <% if (card.docHref) { %>
      <div class="card-text-actions">
        <a href="<%= card.href || '#' %>"<% if (card.external) { %> target="_blank" rel="noopener noreferrer"<% } %> class="arrow-link" aria-label="Learn more">
          <%- include('partials/arrow-icon') %>
        </a>
        <a href="<%= card.docHref %>" class="arrow-link arrow-link--labeled" aria-label="<%= card.docLabel || 'Documentation' %>">
          <span><%= card.docLabel %></span>
          <%- include('partials/arrow-icon') %>
        </a>
      </div>
      <% } else { %>
      <a href="<%= card.href || '#' %>"<% if (card.external) { %> target="_blank" rel="noopener noreferrer"<% } %> class="arrow-link" aria-label="Learn more">
        <%- include('partials/arrow-icon') %>
      </a>
      <% } %>
    </div>
    <div class="card-image">
      <% if (card.darkVideo) { %>
      <video class="video-light" autoplay muted loop playsinline>
        <source src="<%= card.video %>" type="video/mp4">
      </video>
      <video class="video-dark" autoplay muted loop playsinline>
        <source src="<%= card.darkVideo %>" type="video/mp4">
      </video>
      <% } else { %>
      <video autoplay muted loop playsinline>
        <source src="<%= card.video %>" type="video/mp4">
      </video>
      <% } %>
    </div>
  </div>
  <% }) %>
</div>

<!-- Innovation & Research -->
<% if (researchCards && researchCards.length) { var rc = researchCards[0]; %>
<div class="innovation-section" id="about">
  <div class="container">
    <div class="innovation-inner">
      <div class="innovation-text">
        <h2><%= hp.researchSectionTitle || 'Innovation & Research' %></h2>
        <p><%= hp.researchSectionDescription || 'Discover our research explorations across the intersection of design, AI, and human-centered technology.' %></p>
        <% if (rc.href && !rc.comingSoon) { %>
        <a href="<%= rc.href %>"<% if (rc.external) { %> target="_blank" rel="noopener noreferrer"<% } %> class="innovation-cta">Explore the research <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg></a>
        <% } %>
      </div>
      <div class="innovation-image">
        <% if (rc.darkImage) { %>
        <img class="img-light" src="<%= rc.image %>" alt="<%= rc.title %> research visualization">
        <img class="img-dark" src="<%= rc.darkImage %>" alt="<%= rc.title %> research visualization">
        <% } else { %>
        <img src="<%= rc.image %>" alt="<%= rc.title %> research visualization">
        <% } %>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Latest from Our Blog -->
<div class="blog-section" id="blog">
  <div class="container">
    <div class="section-header">
      <h3><%= hp.blogSectionTitle || 'Latest from Our Blog' %></h3>
      <p><%= hp.blogSectionDescription || 'Insights, learnings, and stories from our design team.' %></p>
    </div>
    <div class="blog-cards">
      <% blogPosts.forEach(post => { %>
      <a href="/blog" class="blog-card">
        <div>
          <h4><%= post.title %></h4>
          <p class="blog-desc"><%= post.description %></p>
        </div>
        <div>
          <div class="blog-meta">
            <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> <%= post.author %></span>
            <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg> <%= post.date %></span>
          </div>
          <div class="blog-footer">
            <span><%= post.readTime %></span>
            <span class="read-more">Read more &rarr;</span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
    <div class="section-cta" style="text-align:center;">
      <a href="/blog" class="view-all-btn">View All Articles</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

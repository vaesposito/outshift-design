<header>
  <div class="container">
    <div class="logo">
      <a href="/" style="display:flex;align-items:center;">
        <img src="/images/outshift_logo.svg" alt="Outshift" class="logo-light">
        <img src="/images/outshift_logo-white.svg" alt="Outshift" class="logo-dark">
        <span class="design">design</span>
      </a>
    </div>
    <button class="menu-toggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav>
      <ul>
        <% nav.forEach(item => { %>
        <li<% if (item.children && item.children.length) { %> class="has-dropdown<% if (item.hubDropdown) { %> has-dropdown--hub<% } %>"<% } %>>
          <a href="<%= item.href %>">
            <span class="text"><%= item.label %></span>
            <% if (item.hasDropdown) { %>
            <span class="icon"><img src="/images/keyboard-arrow-down-icon.svg" alt=""></span>
            <% } %>
          </a>
          <% if (item.children && item.children.length) { %>
          <ul class="nav-dropdown<% if (item.label === 'Research') { %> nav-dropdown--research<% } %>">
            <% item.children.forEach(child => { %>
              <% if (child.group) { %>
              <li class="nav-dropdown-group">
                <a href="<%= child.groupHref || '#' %>" class="nav-dropdown-label"><%= child.group %></a>
                <% if (child.items && child.items.length) { %>
                <ul class="nav-dropdown-sub">
                  <% child.items.forEach(sub => { %>
                  <li><a href="<%= sub.href %>"<% if (sub.external) { %> target="_blank" rel="noopener noreferrer"<% } %>><%= sub.label %><% if (sub.external) { %> <svg class="external-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg><% } %></a></li>
                  <% }) %>
                </ul>
                <% } %>
              </li>
              <% } else { %>
              <li><a href="<%= child.href %>"<% if (child.external) { %> target="_blank" rel="noopener noreferrer"<% } %>><%= child.label %><% if (child.external) { %> <svg class="external-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg><% } %></a></li>
              <% } %>
            <% }) %>
          </ul>
          <% } %>
        </li>
        <% }) %>
        <li><button class="theme-toggle" aria-label="Toggle theme"><svg class="icon-moon" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2.5C9.005 3.495 8.447 4.843 8.447 6.25c0 1.407.559 2.755 1.553 3.75.995.995 2.344 1.553 3.75 1.553 1.407 0 2.755-.558 3.75-1.553 0 1.483-.44 2.933-1.264 4.167-.824 1.233-1.995 2.195-3.366 2.762-1.37.568-2.878.716-4.333.427-1.455-.29-2.791-1.004-3.84-2.053-1.049-1.049-1.763-2.386-2.053-3.84a7.502 7.502 0 0 1 .427-4.334A7.502 7.502 0 0 1 5.833 3.764 7.502 7.502 0 0 1 10 2.5Z" stroke="currentColor" stroke-width="1.667" stroke-linecap="round" stroke-linejoin="round"/></svg><svg class="icon-sun" width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="3.333" stroke="currentColor" stroke-width="1.667"/><path d="M10 1.667V3.333M10 16.667V18.333M3.517 3.517l1.178 1.178M15.305 15.305l1.178 1.178M1.667 10H3.333M16.667 10H18.333M3.517 16.483l1.178-1.178M15.305 4.695l1.178-1.178" stroke="currentColor" stroke-width="1.667" stroke-linecap="round"/></svg></button></li>
      </ul>
    </nav>
  </div>
</header>

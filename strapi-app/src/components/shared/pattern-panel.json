{
  "collectionName": "components_shared_pattern_panels",
  "info": {
    "displayName": "PatternPanel",
    "icon": "grid",
    "description": "Pattern panel with key, title, subtitle, descriptions, related patterns, how-to, and pitfalls"
  },
  "options": {},
  "attributes": {
    "key": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "string"
    },
    "description": {
      "type": "text",
      "required": true
    },
    "whatItMeans": {
      "type": "text"
    },
    "whyItMatters": {
      "type": "text"
    },
    "relatedPatterns": {
      "type": "component",
      "repeatable": true,
      "component": "shared.related-pattern"
    },
    "howToImplement": {
      "type": "json"
    },
    "commonPitfalls": {
      "type": "component",
      "repeatable": true,
      "component": "shared.pitfall-card"
    },
    "exampleImages": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "exampleDarkImages": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    }
  }
}

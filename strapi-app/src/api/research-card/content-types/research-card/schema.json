{
  "kind": "collectionType",
  "collectionName": "research_cards",
  "info": {
    "singularName": "research-card",
    "pluralName": "research-cards",
    "displayName": "ResearchCard",
    "description": "Innovation & Research section cards"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "media": {
      "type": "component",
      "repeatable": false,
      "component": "shared.media-block",
      "required": true
    },
    "tags": {
      "type": "component",
      "repeatable": true,
      "component": "shared.tag"
    },
    "link": {
      "type": "component",
      "repeatable": false,
      "component": "shared.arrow-link"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo-meta"
    }
  }
}
